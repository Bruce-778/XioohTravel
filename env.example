# PostgreSQL / Supabase connection string
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"

# Admin token for /admin verification (use a long random string in production)
ADMIN_TOKEN="replace-with-a-strong-random-token"

# JWT signing secret (required, at least 32 chars; generate with: openssl rand -hex 32)
JWT_SECRET="replace-with-64-char-random-hex"

# Comma separated list of admin email addresses (required for admin access)
ADMIN_EMAILS="admin@example.com"

# Stripe payment
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
APP_BASE_URL="https://xioohtravel.vercel.app"

# Transactional email (paid booking confirmation)
RESEND_API_KEY="xxx"
BOOKING_EMAIL_FROM="XioohTravel <onboarding@resend.dev>"
BOOKING_EMAIL_TEST_TO="your-resend-account@example.com"
AUTH_EMAIL_TEST_TO="your-resend-account@example.com"
BOOKING_EMAIL_REPLY_TO=""

# Google Maps API Key (Used for Places Autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
