# PostgreSQL / Supabase connection strings
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"
DIRECT_URL=""

# Admin token for /admin verification (use a long random string in production)
ADMIN_TOKEN="replace-with-a-strong-random-token"

# JWT signing secret (required, at least 32 chars; generate with: openssl rand -hex 32)
JWT_SECRET="replace-with-64-char-random-hex"

# Comma separated list of admin email addresses (required for admin access)
ADMIN_EMAILS="admin@example.com"

# Stripe payment
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
APP_BASE_URL="https://xioohtravel.com"

# Transactional email (auth, paid booking confirmation, refund confirmation)
RESEND_API_KEY="xxx"
BOOKING_EMAIL_FROM="XioohTravel <support@xioohtravel.com>"
BOOKING_EMAIL_REPLY_TO="support@xioohtravel.com"
MERCHANT_EMAILS="ops@example.com,owner@example.com"

# Optional Resend sandbox recipients. Leave empty in production after verifying your sender domain.
BOOKING_EMAIL_TEST_TO=""
AUTH_EMAIL_TEST_TO=""

# Optional display exchange rates. Stripe checkout still charges in JPY.
USD_PER_JPY="0.0067"
CNY_PER_JPY="0.048"

# Google Maps API Key (Used for Places Autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Google Tag Manager container ID, for example GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=""
